<Window x:Class="VoiSpeBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VoiSpeBridge.App.ViewModels"
        xmlns:svc="clr-namespace:VoiSpeBridge.App.Services"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="VoiSpe-Bridge"
        Icon="pack://application:,,,/resource/appicon.png"
        Width="920" Height="680"
        MinWidth="720" MinHeight="520"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <Style x:Key="Label" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>
    <Style x:Key="SliderValue" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Width" Value="40"/>
      <Setter Property="TextAlignment" Value="Right"/>
    </Style>
    <Style x:Key="LevelMeter" TargetType="ProgressBar">
      <Setter Property="Height" Value="6"/>
      <Setter Property="Minimum" Value="0"/>
      <Setter Property="Maximum" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
      <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <!-- ヘッダー内の小ボタン -->
    <Style x:Key="HeaderIconButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="5"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <!-- ヘッダー内のプラグイン情報ボタン -->
    <Style x:Key="HeaderPluginButton" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- ヘッダーバー -->
      <RowDefinition Height="10"/>
      <RowDefinition Height="*"/>     <!-- メインコンテンツ -->
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="12"/>
      <ColumnDefinition Width="270"/>
    </Grid.ColumnDefinitions>

    <!-- ===== ヘッダーバー（全幅） ===== -->
    <Border Grid.Row="0" Grid.ColumnSpan="3"
            Background="{StaticResource SurfaceBrush}"
            CornerRadius="8" Padding="12,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>  <!-- タイトル -->
          <ColumnDefinition Width="*"/>     <!-- スペーサー -->
          <ColumnDefinition Width="Auto"/>  <!-- プラグイン情報 -->
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="Auto"/>  <!-- 辞書プリセット -->
        </Grid.ColumnDefinitions>

        <!-- アプリタイトル -->
        <TextBlock Grid.Column="0"
                   Text="VoiSpe-Bridge"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{StaticResource AccentBrush}"
                   VerticalAlignment="Center"/>

        <!-- プラグイン・音声パラメータ設定ボタン -->
        <StackPanel Grid.Column="2" Orientation="Horizontal"
                    VerticalAlignment="Center">
          <TextBlock Text="{Binding PluginCastLabel}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="11" VerticalAlignment="Center"
                     Margin="0,0,6,0"/>
          <Button Content="{Binding ThemeToggleLabel}"
                  Command="{Binding ToggleThemeCommand}"
                  Style="{StaticResource HeaderIconButton}"
                  Margin="0,0,6,0"
                  FontSize="16"
                  ToolTip="ダーク / ライト テーマを切り替え"/>
          <Button Content="🖥 配信用字幕"
                  Command="{Binding ToggleSubtitleWindowCommand}"
                  Style="{StaticResource HeaderPluginButton}"
                  Margin="0,0,6,0"
                  ToolTip="グリーンバック字幕ウィンドウを表示／非表示"/>
          <Button Content="⚙ 音声合成設定"
                  Command="{Binding OpenPluginSettingsCommand}"
                  Style="{StaticResource HeaderPluginButton}"/>
        </StackPanel>

        <!-- 辞書プリセット -->
        <StackPanel Grid.Column="4" Orientation="Horizontal"
                    VerticalAlignment="Center">
          <TextBlock Text="辞書:"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="11" VerticalAlignment="Center"
                     Margin="0,0,5,0"/>
          <ComboBox ItemsSource="{Binding DictionaryPresets}"
                    SelectedItem="{Binding SelectedDictionaryPreset}"
                    Width="120" Padding="6,3"
                    IsEnabled="{Binding IsModelLoading, Converter={StaticResource InverseBool}}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Content="＋"
                  Command="{Binding AddPresetCommand}"
                  Style="{StaticResource HeaderIconButton}"
                  ToolTip="新しいプリセットを追加"
                  Margin="3,0,0,0"/>
          <Button Content="✎"
                  Command="{Binding EditPresetCommand}"
                  Style="{StaticResource HeaderIconButton}"
                  ToolTip="選択中のプリセットを編集"/>
          <Button Content="✕"
                  Command="{Binding DeletePresetCommand}"
                  Style="{StaticResource HeaderIconButton}"
                  Foreground="{StaticResource DangerBrush}"
                  ToolTip="選択中のプリセットを削除"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ===== 左列：メイン操作 ===== -->
    <Grid Grid.Row="2" Grid.Column="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- ステータス＋操作バー -->
      <Border Grid.Row="0" Style="{StaticResource Card}">
        <StackPanel>
          <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
              <TextBlock Text="{Binding StatusText}"
                         FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="モデル準備中... しばらくお待ちください"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="11"
                         Visibility="{Binding IsModelLoading,
                           Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="{Binding ListenButtonLabel}"
                    Command="{Binding ToggleListenCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,8,0" MinWidth="120"/>
            <Button Grid.Column="2"
                    Content="■ 停止"
                    Command="{Binding StopSpeakingCommand}"
                    Style="{StaticResource DangerButton}"
                    MinWidth="70"/>
          </Grid>

          <!-- 音声入力レベルメーター -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="60"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <TextBlock Style="{StaticResource Label}"
                       Text="マイク入力" VerticalAlignment="Center"/>
            <ProgressBar Grid.Column="1"
                         Style="{StaticResource LevelMeter}"
                         Value="{Binding AudioLevel}"
                         VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2"
                       Text="{Binding AudioLevelDbText}"
                       FontSize="10"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       TextAlignment="Right" Margin="4,0,0,0"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- 認識テキスト -->
      <Border Grid.Row="1" Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Style="{StaticResource Label}"
                     Text="認識テキスト（クリックで再読み上げ）"/>
          <Border Background="{StaticResource BackgroundBrush}"
                  CornerRadius="4" Padding="10,8" Cursor="Hand"
                  MinHeight="44">
            <Border.InputBindings>
              <MouseBinding MouseAction="LeftClick"
                            Command="{Binding SpeakTextCommand}"
                            CommandParameter="{Binding RecognizedText}"/>
            </Border.InputBindings>
            <TextBlock Text="{Binding RecognizedText}"
                       FontSize="15" TextWrapping="Wrap"/>
          </Border>
        </StackPanel>
      </Border>

      <!-- 手動入力 + 履歴 -->
      <Border Grid.Row="2" Style="{StaticResource Card}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Style="{StaticResource Label}" Text="手動入力（Enter で読み上げ）"/>
          <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="8"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding ManualInput, UpdateSourceTrigger=PropertyChanged}"
                     Background="{StaticResource BackgroundBrush}">
              <TextBox.InputBindings>
                <KeyBinding Key="Return"
                            Command="{Binding SpeakTextCommand}"
                            CommandParameter="{Binding ManualInput}"/>
              </TextBox.InputBindings>
            </TextBox>
            <Button Grid.Column="2" Content="読み上げ"
                    Command="{Binding SpeakTextCommand}"
                    CommandParameter="{Binding ManualInput}"
                    Style="{StaticResource PrimaryButton}"/>
          </Grid>

          <!-- 履歴 -->
          <Grid Grid.Row="2">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,4">
              <TextBlock Style="{StaticResource Label}" Text="発話履歴"/>
              <Button HorizontalAlignment="Right" Content="クリア"
                      Command="{Binding ClearHistoryCommand}"
                      Padding="8,2" FontSize="11"
                      Background="Transparent"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      BorderThickness="0" Cursor="Hand"/>
            </Grid>
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding History}"
                     Background="{StaticResource BackgroundBrush}"
                     BorderBrush="{StaticResource BorderBrush}"
                     BorderThickness="1">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="4,3">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="60"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding DisplayTime}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"/>
                    <TextBlock Grid.Column="1" Text="{Binding Text}"
                               TextWrapping="Wrap" FontSize="13"/>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <!-- ===== 右列：音声認識設定のみ ===== -->
    <ScrollViewer Grid.Row="2" Grid.Column="2"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel>

        <!-- 音声認識設定 -->
        <Border Style="{StaticResource Card}">
          <StackPanel>
            <TextBlock Text="音声認識"
                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <!-- 認識エンジン選択 -->
            <TextBlock Style="{StaticResource Label}" Text="認識エンジン"/>
            <ComboBox ItemsSource="{Binding AvailableEngines}"
                      SelectedItem="{Binding SelectedEngine}"
                      Margin="0,0,0,4">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource EngineTypeToLabel}}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <!-- ブラウザ音声認識の説明（Browser エンジン選択時のみ表示） -->
            <Border Background="{StaticResource BackgroundBrush}"
                    CornerRadius="4" Padding="8"
                    Margin="0,4,0,8"
                    Visibility="{Binding IsBrowserEngine, Converter={StaticResource BoolToVis}}">
              <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="10" TextWrapping="Wrap">
                ● Google の音声認識サーバーで処理されます（音声データが送信されます）&#x0a;
                ● GPU を使用しないためゲーム配信中の負荷を大幅に軽減できます&#x0a;
                ● WebView2（Chromium）ベースで動作します&#x0a;
                ● 発話検出はブラウザ側で自動処理されます
              </TextBlock>
            </Border>

            <!-- ReazonSpeech の説明（ReazonSpeech エンジン選択時のみ表示） -->
            <Border Background="{StaticResource BackgroundBrush}"
                    CornerRadius="4" Padding="8"
                    Margin="0,4,0,8"
                    Visibility="{Binding IsReazonSpeechEngine, Converter={StaticResource BoolToVis}}">
              <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="10" TextWrapping="Wrap">
                ● 日本語特化ローカル実行エンジン（GPU 不要・完全オフライン）&#x0a;
                ● ReazonSpeech データセットで訓練された高精度日本語モデル&#x0a;
                ● 初回のみモデルを自動ダウンロードします（数百MB・数分）
              </TextBlock>
            </Border>

            <!-- Whisper 専用設定（モデル選択・GPU）-->
            <StackPanel Visibility="{Binding IsWhisperEngine,
                                    Converter={StaticResource BoolToVis}}">
              <TextBlock Style="{StaticResource Label}" Text="Whisper モデル"/>
              <ComboBox ItemsSource="{Binding AvailableModels}"
                        SelectedItem="{Binding SelectedModel}"
                        IsEnabled="{Binding IsModelLoading, Converter={StaticResource InverseBool}}"
                        Margin="0,0,0,4">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource ModelTypeToLabel}}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8">
                ゲーム中は Large v3 Turbo または Base を推奨。初回は自動ダウンロード。
                変更するとモデルが再読み込みされます。
              </TextBlock>

              <CheckBox IsChecked="{Binding UseGpu}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Margin="0,0,0,2">
                <TextBlock Text="GPU アクセラレーション（推奨）" FontSize="12"/>
              </CheckBox>
              <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="10" TextWrapping="Wrap" Margin="0,0,0,10">
                NVIDIA: CUDA、AMD/Intel: Vulkan を自動選択。
                変更するとモデルが再読み込みされます。
              </TextBlock>
            </StackPanel>

            <!-- VAD 設定（Whisper・ReazonSpeech 共通）-->
            <StackPanel Visibility="{Binding ShowVadSettings,
                                    Converter={StaticResource BoolToVis}}">

              <!-- 発話検出レベル -->
              <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource Label}" Text="発話検出レベル"/>
                <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                           Text="{Binding VoiceTriggerDb, StringFormat='{}{0:F0} dB'}"/>
              </Grid>
              <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="-50" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="-50" Maximum="0"
                        Value="{Binding VoiceTriggerDb}"
                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="4,0"/>
                <TextBlock Grid.Column="2" Text="0" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              </Grid>
              <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8">
                この音量を超えると発話開始とみなします。
                BGM 等がある場合は高め (-15〜-10 dB) に。
              </TextBlock>

              <!-- ノイズゲート -->
              <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource Label}" Text="ノイズゲート（下限）"/>
                <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                           Text="{Binding NoiseGateDb, StringFormat='{}{0:F0} dB'}"/>
              </Grid>
              <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="-60" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="-60" Maximum="-10"
                        Value="{Binding NoiseGateDb}"
                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="4,0"/>
                <TextBlock Grid.Column="2" Text="-10" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              </Grid>
              <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="10" TextWrapping="Wrap" Margin="0,0,0,10">
                発話検出レベルより低く設定してください
                （目安: 検出レベル − 10〜20 dB）。
              </TextBlock>

              <!-- 無音判定時間 -->
              <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource Label}" Text="無音で確定 (ms)"/>
                <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                           Text="{Binding SilenceDurationMs}"/>
              </Grid>
              <Slider Minimum="300" Maximum="2000"
                      Value="{Binding SilenceDurationMs}"
                      TickFrequency="10" IsSnapToTickEnabled="True"
                      Margin="0,0,0,4"/>
              <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="10" TextWrapping="Wrap" Margin="0,0,0,10">
                発話後この時間無音が続くと自動で確定・読み上げします。
              </TextBlock>

              <!-- 最小発話時間（誤検出フィルタ） -->
              <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource Label}" Text="最小発話時間"/>
                <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                           Text="{Binding MinActiveSpeechMs, StringFormat='{}{0} ms'}"/>
              </Grid>
              <Slider Minimum="50" Maximum="1000"
                      Value="{Binding MinActiveSpeechMs}"
                      TickFrequency="50" IsSnapToTickEnabled="True"
                      Margin="0,0,0,4"/>
              <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="10" TextWrapping="Wrap" Margin="0,0,0,10">
                擦れ音など瞬間的なノイズを除外します。推奨: 150〜300ms。
              </TextBlock>

              <!-- 最小認識文字数（誤検出フィルタ） -->
              <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource Label}" Text="最小認識文字数"/>
                <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                           Text="{Binding MinRecognizedTextLength, StringFormat='{}{0} 文字'}"/>
              </Grid>
              <Slider Minimum="1" Maximum="5"
                      Value="{Binding MinRecognizedTextLength}"
                      TickFrequency="1" IsSnapToTickEnabled="True"
                      Margin="0,0,0,4"/>
              <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="10" TextWrapping="Wrap">
                この文字数未満の認識結果を破棄します。「え」など1文字誤検出を除くには 2 に設定。
              </TextBlock>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- 配信用字幕設定 -->
        <Border Style="{StaticResource Card}">
          <StackPanel>
            <TextBlock Text="配信用字幕"
                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <!-- フォント選択 -->
            <TextBlock Style="{StaticResource Label}" Text="フォント"/>
            <ComboBox ItemsSource="{Binding Subtitle.InstalledFonts}"
                      SelectedItem="{Binding Subtitle.FontFamilyName}"
                      Margin="0,0,0,8"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- フォントサイズ -->
            <Grid Margin="0,0,0,2">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Style="{StaticResource Label}" Text="フォントサイズ"/>
              <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                         Text="{Binding Subtitle.FontSize, StringFormat='{}{0:F0}'}"/>
            </Grid>
            <Slider Minimum="20" Maximum="200"
                    Value="{Binding Subtitle.FontSize}"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    Margin="0,0,0,10"/>

            <!-- 縁取りの太さ -->
            <Grid Margin="0,0,0,2">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Style="{StaticResource Label}" Text="縁取りの太さ"/>
              <TextBlock Grid.Column="1" Style="{StaticResource SliderValue}"
                         Text="{Binding Subtitle.StrokeThickness, StringFormat='{}{0:F0}'}"/>
            </Grid>
            <Slider Minimum="0" Maximum="40"
                    Value="{Binding Subtitle.StrokeThickness}"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    Margin="0,0,0,10"/>

            <!-- 文字色 ／ 縁取り色 -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- 文字色 -->
              <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource Label}" Text="文字色"/>
                <Button Height="30"
                        Click="OnPickFontColor"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Padding="4,0"
                        Cursor="Hand"
                        ToolTip="クリックしてカラーピッカーを開く">
                  <Button.Background>
                    <SolidColorBrush Color="{Binding Subtitle.FontColor}"/>
                  </Button.Background>
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                    </ControlTemplate>
                  </Button.Template>
                  <Rectangle Height="14" Margin="6,0" RadiusX="2" RadiusY="2">
                    <Rectangle.Fill>
                      <SolidColorBrush Color="{Binding Subtitle.FontColor}"/>
                    </Rectangle.Fill>
                  </Rectangle>
                </Button>
              </StackPanel>

              <!-- 縁取り色 -->
              <StackPanel Grid.Column="2">
                <TextBlock Style="{StaticResource Label}" Text="縁取り色"/>
                <Button Height="30"
                        Click="OnPickStrokeColor"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Padding="4,0"
                        Cursor="Hand"
                        ToolTip="クリックしてカラーピッカーを開く">
                  <Button.Background>
                    <SolidColorBrush Color="{Binding Subtitle.StrokeColor}"/>
                  </Button.Background>
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                    </ControlTemplate>
                  </Button.Template>
                  <Rectangle Height="14" Margin="6,0" RadiusX="2" RadiusY="2">
                    <Rectangle.Fill>
                      <SolidColorBrush Color="{Binding Subtitle.StrokeColor}"/>
                    </Rectangle.Fill>
                  </Rectangle>
                </Button>
              </StackPanel>
            </Grid>

            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="10" TextWrapping="Wrap" Margin="0,8,0,0">
              OBS：ウィンドウキャプチャ →「VoiSpe-Bridge - 配信用字幕」→
              フィルタ →「クロマキー」→ 緑 (#00FF00) を設定してください。
              上部の帯はクロップで除外できます。
            </TextBlock>
          </StackPanel>
        </Border>

        <TextBlock Text="VoiSpe-Bridge v1.0"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="11" HorizontalAlignment="Center" Margin="0,4"/>
      </StackPanel>
    </ScrollViewer>

    <!-- WebView2（ブラウザ音声認識用・非表示で常駐） -->
    <!-- Opacity は WebView2 の HWND に直接適用できないため Border でラップして隠す -->
    <Border Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="3"
            Width="1" Height="1"
            HorizontalAlignment="Left" VerticalAlignment="Top"
            Opacity="0" IsHitTestVisible="False">
      <wv2:WebView2 x:Name="BrowserWebView" Width="1" Height="1"/>
    </Border>

  </Grid>
</Window>
