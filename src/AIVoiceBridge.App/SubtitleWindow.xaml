<Window x:Class="VoiSpeBridge.App.SubtitleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:VoiSpeBridge.App.Controls"
        Title="VoiSpe-Bridge - 配信用字幕"
        Width="900" Height="180"
        MinWidth="300" MinHeight="80"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#FF00FF00"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        ShowInTaskbar="True">

  <!-- 全体がグリーンバック。DragMove() はコードビハインドで実装。
       OBS 等のキャプチャソフトで「ウィンドウキャプチャ」→ クロマキー(#00FF00) を設定してください。 -->
  <Grid>

    <!-- ── ドラッグ用ハンドル（上端 28px・半透明黒）────
         OBS ではこの帯をクロップして除外してください。
         このエリアでマウスドラッグするとウィンドウを移動できます。 -->
    <Border x:Name="DragHandle"
            Height="28"
            VerticalAlignment="Top"
            Background="#BB000000"
            Cursor="SizeAll"
            MouseLeftButtonDown="OnDragHandleMouseDown">
      <Grid>
        <TextBlock Text="配信用字幕  ／  ドラッグで移動  ／  右下角でリサイズ"
                   Foreground="#88FFFFFF"
                   FontSize="10"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>
        <Button Content="✕"
                Width="28" Height="28"
                HorizontalAlignment="Right"
                Background="Transparent"
                Foreground="#AAFFFFFF"
                BorderThickness="0"
                FontSize="13"
                Cursor="Hand"
                Click="OnCloseClick"
                ToolTip="字幕ウィンドウを非表示にする"/>
      </Grid>
    </Border>

    <!-- ── 字幕テキスト（グリーンバック領域）──── -->
    <ctrl:OutlinedTextBlock
        x:Name="SubtitleText"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Margin="24,36,24,12"
        Text="{Binding DisplayText}"
        FontFamilyName="{Binding FontFamilyName}"
        FontSize="{Binding FontSize}"
        FillBrush="{Binding FontBrush}"
        StrokeBrush="{Binding StrokeBrush}"
        StrokeThickness="{Binding StrokeThickness}"/>

  </Grid>
</Window>
