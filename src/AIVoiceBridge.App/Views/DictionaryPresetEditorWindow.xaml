<Window x:Class="AIVoiceBridge.App.Views.DictionaryPresetEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プリセット編集"
        Width="580" Height="540"
        MinWidth="480" MinHeight="400"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

  <Window.Resources>
    <Style x:Key="Label" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>
    <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="Normal"/>
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- プリセット名 -->
    <StackPanel Grid.Row="0" Margin="0,0,0,12">
      <TextBlock Style="{StaticResource Label}" Text="プリセット名"/>
      <TextBox x:Name="PresetNameBox"
               Text="{Binding Preset.Name, Mode=OneTime}"
               FontSize="14"/>
    </StackPanel>

    <!-- Initial Prompt -->
    <StackPanel Grid.Row="1" Margin="0,0,0,12">
      <TextBlock Style="{StaticResource Label}" Text="initial_prompt（固有名詞を列挙して認識精度を上げます）"/>
      <TextBox x:Name="InitialPromptBox"
               Text="{Binding Preset.InitialPrompt, Mode=OneTime}"
               Height="72"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto"
               FontSize="12"/>
      <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"
                 TextWrapping="Wrap" Margin="0,3,0,0">
        例: 「この配信では SynthesizerV、A.I.VOICE2 について話します。」
        プリセット切り替え後に認識を再起動すると反映されます。
      </TextBlock>
    </StackPanel>

    <!-- Dictionary DataGrid -->
    <Grid Grid.Row="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Style="{StaticResource Label}"
                 Text="後変換辞書（誤変換 → 正しい表記へ置換）" Margin="0,0,0,4"/>

      <DataGrid Grid.Row="1"
                x:Name="EntriesGrid"
                ItemsSource="{Binding Entries}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                HeadersVisibility="Column"
                GridLinesVisibility="Horizontal"
                RowBackground="{StaticResource SurfaceBrush}"
                AlternatingRowBackground="{StaticResource BackgroundBrush}"
                Foreground="{StaticResource TextPrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                ColumnHeaderHeight="28"
                RowHeight="30"
                FontSize="12">
        <DataGrid.ColumnHeaderStyle>
          <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
          </Style>
        </DataGrid.ColumnHeaderStyle>
        <DataGrid.CellStyle>
          <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </DataGrid.CellStyle>
        <DataGrid.Columns>
          <DataGridTextColumn Header="正しい表記" Binding="{Binding CorrectForm}"
                              Width="160" MinWidth="100"/>
          <DataGridTextColumn Header="誤認識パターン（カンマ区切り）"
                              Binding="{Binding VariantsText}"
                              Width="*" MinWidth="160"/>
        </DataGrid.Columns>
      </DataGrid>

      <!-- Add / Delete row buttons -->
      <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
        <Button Content="＋ 行を追加" Click="AddEntry_Click"
                Style="{StaticResource SmallButton}" Margin="0,0,6,0"/>
        <Button Content="－ 選択行を削除" Click="DeleteEntry_Click"
                Style="{StaticResource DangerButton}"
                Padding="10,5" FontSize="12" FontWeight="Normal"/>
      </StackPanel>
    </Grid>

    <!-- OK / Cancel -->
    <StackPanel Grid.Row="3" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Content="キャンセル" Click="Cancel_Click"
              Style="{StaticResource SmallButton}"
              Background="{StaticResource BorderBrush}"
              Margin="0,0,8,0" MinWidth="90"/>
      <Button Content="OK" Click="OK_Click"
              Style="{StaticResource SmallButton}"
              MinWidth="90"/>
    </StackPanel>
  </Grid>
</Window>
