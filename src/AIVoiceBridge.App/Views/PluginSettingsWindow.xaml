<Window x:Class="VoiSpeBridge.App.Views.PluginSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:VoiSpeBridge.App.Converters"
        Title="音声合成設定"
        Width="700" Height="720"
        MinWidth="520" MinHeight="400"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

  <Window.Resources>
    <Style x:Key="SectionLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
    <Style x:Key="SliderValue" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Width" Value="38"/>
      <Setter Property="TextAlignment" Value="Right"/>
    </Style>
    <!-- 小パラメータラベル行（ラベル左・値右） -->
    <Style x:Key="ParamRow" TargetType="Grid">
      <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>
  </Window.Resources>

  <Grid Margin="14,12,14,10">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>    <!-- 2カラム コンテンツ -->
      <RowDefinition Height="10"/>
      <RowDefinition Height="Auto"/> <!-- 閉じるボタン -->
    </Grid.RowDefinitions>

    <!-- ══════════ 2カラム メインコンテンツ ══════════ -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>   <!-- 左列 -->
        <ColumnDefinition Width="10"/>  <!-- 区切り -->
        <ColumnDefinition Width="*"/>   <!-- 右列 -->
      </Grid.ColumnDefinitions>

      <!-- ━━━━━ 左列：プラグイン / 接続設定 / 音声パラメータ / 感情 ━━━━━ -->
      <ScrollViewer Grid.Column="0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

          <!-- プラグイン・キャスト -->
          <Border Style="{StaticResource Card}">
            <StackPanel>
              <TextBlock Text="プラグイン・キャスト"
                         FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>

              <TextBlock Style="{StaticResource SectionLabel}" Text="プラグイン"/>
              <ComboBox ItemsSource="{Binding AvailablePlugins}"
                        SelectedItem="{Binding SelectedPlugin}"
                        Margin="0,0,0,8">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <TextBlock Style="{StaticResource SectionLabel}" Text="キャスト（ボイス）"/>
              <ComboBox ItemsSource="{Binding AvailableCasts}"
                        SelectedItem="{Binding SelectedCast}"
                        IsEnabled="{Binding IsCastSelectable}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Margin="0,4,0,0"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="10" TextWrapping="Wrap"
                         Visibility="{Binding IsCastSelectable,
                           Converter={StaticResource InverseVis}}">
                A.I.VOICE2 はキャストをAPI経由で取得できません。
                A.I.VOICE2 Editor 側で選択中のキャストが使用されます。
              </TextBlock>
            </StackPanel>
          </Border>

          <!-- 接続設定（IPluginWithConnectionSettings 実装プラグイン向け・動的表示） -->
          <Border Style="{StaticResource Card}"
                  Visibility="{Binding HasPluginConnectionSettings,
                               Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Text="接続設定"
                         FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>

              <ItemsControl ItemsSource="{Binding PluginConnectionSettings}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Margin="0,0,0,8">
                      <TextBlock Style="{StaticResource SectionLabel}" Text="{Binding Label}"/>
                      <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                               Visibility="{Binding IsPassword,
                                            Converter={StaticResource InverseVis}}"/>
                      <PasswordBox conv:PasswordBoxHelper.BoundPassword="{Binding Value, Mode=TwoWay,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                   Visibility="{Binding IsPassword,
                                                Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="10" TextWrapping="Wrap" Margin="0,4,0,10">
                VoisonaTalk の 設定 &gt; API タブで REST API を有効化し、
                メールアドレスと API パスワードを設定してください。
              </TextBlock>

              <Button Content="再接続"
                      Command="{Binding ReconnectPluginCommand}"
                      HorizontalAlignment="Right"
                      Style="{StaticResource PrimaryButton}"
                      Padding="16,5" FontSize="12"/>
            </StackPanel>
          </Border>

          <!-- 音声パラメータ -->
          <Border Style="{StaticResource Card}">
            <StackPanel>
              <TextBlock Text="音声パラメータ"
                         FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>

              <Grid Style="{StaticResource ParamRow}">
                <TextBlock Style="{StaticResource SectionLabel}" Text="話速"/>
                <TextBlock HorizontalAlignment="Right" Style="{StaticResource SliderValue}"
                           Text="{Binding Speed, StringFormat=F2}"/>
              </Grid>
              <Slider Minimum="0.5" Maximum="2.0" Value="{Binding Speed}"
                      TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,8"/>

              <Grid Style="{StaticResource ParamRow}">
                <TextBlock Style="{StaticResource SectionLabel}" Text="音量"/>
                <TextBlock HorizontalAlignment="Right" Style="{StaticResource SliderValue}"
                           Text="{Binding Volume, StringFormat=F2}"/>
              </Grid>
              <Slider Minimum="0.0" Maximum="2.0" Value="{Binding Volume}"
                      TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,8"/>

              <Grid Style="{StaticResource ParamRow}">
                <TextBlock Style="{StaticResource SectionLabel}" Text="ピッチ"/>
                <TextBlock HorizontalAlignment="Right" Style="{StaticResource SliderValue}"
                           Text="{Binding Pitch, StringFormat=F2}"/>
              </Grid>
              <Slider Minimum="0.5" Maximum="2.0" Value="{Binding Pitch}"
                      TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,8"/>

              <Grid Style="{StaticResource ParamRow}">
                <TextBlock Style="{StaticResource SectionLabel}" Text="抑揚"/>
                <TextBlock HorizontalAlignment="Right" Style="{StaticResource SliderValue}"
                           Text="{Binding Intonation, StringFormat=F2}"/>
              </Grid>
              <Slider Minimum="0.0" Maximum="2.0" Value="{Binding Intonation}"
                      TickFrequency="0.01" IsSnapToTickEnabled="True"/>
            </StackPanel>
          </Border>

          <!-- 感情・スタイル（IPluginWithEmotions 実装プラグイン向け・動的表示） -->
          <Border Style="{StaticResource Card}"
                  Visibility="{Binding HasEmotionParameters,
                               Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Text="感情・スタイル"
                         FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>

              <ItemsControl ItemsSource="{Binding EmotionParameters}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Margin="0,0,0,8">
                      <Grid Style="{StaticResource ParamRow}">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="{Binding Label}"/>
                        <TextBlock HorizontalAlignment="Right" Style="{StaticResource SliderValue}"
                                   Text="{Binding Value, StringFormat=F0}"/>
                      </Grid>
                      <Slider Minimum="{Binding Min}" Maximum="{Binding Max}"
                              Value="{Binding Value}"
                              TickFrequency="1" IsSnapToTickEnabled="True"/>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- ━━━━━ 右列：声量キャスト自動切り替え / 出力デバイス ━━━━━ -->
      <ScrollViewer Grid.Column="2"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

          <!-- 声量キャスト自動切り替え -->
          <Border Style="{StaticResource Card}">
            <StackPanel>
              <CheckBox IsChecked="{Binding VolumePresetEnabled}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Margin="0,0,0,6">
                <TextBlock Text="声量でキャストを自動切り替え"
                           FontSize="12" FontWeight="SemiBold"/>
              </CheckBox>
              <TextBlock Style="{StaticResource SectionLabel}"
                         TextWrapping="Wrap" Margin="0,0,0,8">
                発話ごとの平均音量を計測し、しきい値以上なら「音量大」キャストへ自動切り替えします。
                Whisper・ReazonSpeech エンジン使用時のみ動作します。
              </TextBlock>

              <StackPanel Visibility="{Binding VolumePresetEnabled,
                                      Converter={StaticResource BoolToVis}}">

                <!-- 音量大しきい値 -->
                <Grid Style="{StaticResource ParamRow}">
                  <TextBlock Style="{StaticResource SectionLabel}" Text="音量大しきい値"/>
                  <TextBlock HorizontalAlignment="Right" Style="{StaticResource SliderValue}"
                             Text="{Binding LoudVolumeThresholdDb, StringFormat='{}{0:F0} dB'}"/>
                </Grid>
                <Slider Minimum="-50" Maximum="0"
                        Value="{Binding LoudVolumeThresholdDb}"
                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,2"/>
                <TextBlock Style="{StaticResource SectionLabel}"
                           TextWrapping="Wrap" Margin="0,0,0,10">
                  推奨: -20〜-15 dB。音声レベルメーターの値を参考に設定してください。
                </TextBlock>

                <!-- 通常声量キャスト -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="通常声量のキャスト"/>
                <ComboBox ItemsSource="{Binding AvailableCasts}"
                          SelectedItem="{Binding NormalVolumeCast}"
                          Margin="0,0,0,10">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- 音量大キャスト -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="音量大のキャスト（叫び声など）"/>
                <ComboBox ItemsSource="{Binding AvailableCasts}"
                          SelectedItem="{Binding LoudVolumeCast}"
                          Margin="0,0,0,12">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- 音量大時の音声パラメータ -->
                <TextBlock Text="音量大時の音声パラメータ"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,8"/>

                <Grid Style="{StaticResource ParamRow}">
                  <TextBlock Style="{StaticResource SectionLabel}" Text="話速"/>
                  <TextBlock HorizontalAlignment="Right" Style="{StaticResource SliderValue}"
                             Text="{Binding LoudCastSpeed, StringFormat=F2}"/>
                </Grid>
                <Slider Minimum="0.5" Maximum="2.0" Value="{Binding LoudCastSpeed}"
                        TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,8"/>

                <Grid Style="{StaticResource ParamRow}">
                  <TextBlock Style="{StaticResource SectionLabel}" Text="音量"/>
                  <TextBlock HorizontalAlignment="Right" Style="{StaticResource SliderValue}"
                             Text="{Binding LoudCastVolume, StringFormat=F2}"/>
                </Grid>
                <Slider Minimum="0.0" Maximum="2.0" Value="{Binding LoudCastVolume}"
                        TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,8"/>

                <Grid Style="{StaticResource ParamRow}">
                  <TextBlock Style="{StaticResource SectionLabel}" Text="ピッチ"/>
                  <TextBlock HorizontalAlignment="Right" Style="{StaticResource SliderValue}"
                             Text="{Binding LoudCastPitch, StringFormat=F2}"/>
                </Grid>
                <Slider Minimum="0.5" Maximum="2.0" Value="{Binding LoudCastPitch}"
                        TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,8"/>

                <Grid Style="{StaticResource ParamRow}">
                  <TextBlock Style="{StaticResource SectionLabel}" Text="抑揚"/>
                  <TextBlock HorizontalAlignment="Right" Style="{StaticResource SliderValue}"
                             Text="{Binding LoudCastIntonation, StringFormat=F2}"/>
                </Grid>
                <Slider Minimum="0.0" Maximum="2.0" Value="{Binding LoudCastIntonation}"
                        TickFrequency="0.01" IsSnapToTickEnabled="True"/>

              </StackPanel>
            </StackPanel>
          </Border>

          <!-- 出力デバイス -->
          <Border Style="{StaticResource Card}">
            <StackPanel>
              <TextBlock Text="音声出力 / OBS連携"
                         FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <TextBlock Style="{StaticResource SectionLabel}" Text="出力デバイス"/>
              <ComboBox ItemsSource="{Binding OutputDevices}"
                        SelectedItem="{Binding SelectedOutputDevice}"
                        Margin="0,0,0,6">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="10" TextWrapping="Wrap">
                VB-Cable 等の仮想デバイスを選択し、OBS の「音声入力キャプチャ」で
                同じデバイスを指定すると合成音声を取り込めます。
              </TextBlock>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

    </Grid>

    <!-- 閉じるボタン -->
    <Button Grid.Row="2"
            Content="閉じる" Click="Close_Click"
            HorizontalAlignment="Right"
            Style="{StaticResource PrimaryButton}"
            Background="{StaticResource BorderBrush}"
            Padding="20,7" FontSize="13" FontWeight="Normal"/>
  </Grid>
</Window>
